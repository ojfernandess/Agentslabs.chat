{
	"extends": "@rocket.chat/tsconfig/client.json",
	"compilerOptions": {
		"rootDir": "./src",
		"outDir": "./dist",
		"target": "es6",
		"module": "Node16",
		"moduleResolution": "node16",
		"esModuleInterop": true,
		"sourceMap": true
	},
	"include": ["./src/**/*"],
	"exclude": ["**/*.spec.ts", "**/*.test.ts"]
}
