# Copie para .env na máquina local (não commitado) ou defina as mesmas variáveis no EasyPanel.

# URL pública do workspace (obrigatório em produção)
ROOT_URL=https://chat.seudominio.com

# MongoDB — replica set obrigatório (pode ser Atlas ou o serviço `mongo` do compose)
MONGO_URL=mongodb://mongo:27017/rocketchat?replicaSet=rs0
MONGO_OPLOG_URL=mongodb://mongo:27017/local?replicaSet=rs0

# Opcional: microserviços EE / NATS (só se usar stack completa tipo docker-compose-local)
# TRANSPORTER=nats://nats:4222

# Build Docker (CI local — raramente necessário)
# NPM_TOKEN=
