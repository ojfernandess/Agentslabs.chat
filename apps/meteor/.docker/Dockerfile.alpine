FROM node:22.16.0-alpine3.20 AS builder

ENV LANG=C.UTF-8

RUN apk add --no-cache python3 make g++ py3-setuptools libc6-compat

COPY . /app

ENV NODE_ENV=production

# federation-matrix imports hono/factory & hono/combine. Meteor's require() does not use npm "exports"
# and looks for real paths under node_modules/hono/{factory,combine}. Install hono and add CJS shims.
RUN cd /app/bundle/programs/server \
    && npm install --omit=dev \
    && npm install hono@4.12.5 --omit=dev --no-save \
    && cd node_modules/hono \
    && mkdir -p factory combine \
    && printf '%s\n' "module.exports = require('../dist/cjs/helper/factory/index.js');" > factory/index.js \
    && printf '%s\n' "module.exports = require('../dist/cjs/middleware/combine/index.js');" > combine/index.js

FROM node:22.16.0-alpine3.20

LABEL maintainer="Agents Labs Chat PRO" \
      org.opencontainers.image.source="https://github.com/ojfernandess/Agentslabs.chat"

ENV LANG=C.UTF-8

RUN apk add --no-cache shadow deno ttf-dejavu \
    && apk upgrade --no-cache openssl \
    && groupmod -n rocketchat nogroup \
    && useradd -u 65533 -r -g rocketchat rocketchat

ENV DEPLOY_METHOD=docker \
    NODE_ENV=production \
    MONGO_URL=mongodb://mongo:27017/rocketchat \
    HOME=/tmp \
    PORT=3000 \
    ROOT_URL=http://localhost:3000 \
    Accounts_AvatarStorePath=/app/uploads

COPY --from=builder --chown=rocketchat:rocketchat /app /app

# Runtime fallback: install hono + shims if image/bundle predates the fix above.
RUN printf '%s\n' \
    '#!/bin/sh' \
    'set -e' \
    'cd /app/bundle/programs/server' \
    'if [ ! -d node_modules/hono ]; then' \
    '  echo "[docker-entrypoint] installing hono..."' \
    '  npm install hono@4.12.5 --omit=dev --no-save' \
    'fi' \
    'H=/app/bundle/programs/server/node_modules/hono' \
    'if [ ! -f "$H/factory/index.js" ]; then' \
    '  echo "[docker-entrypoint] adding hono/factory + hono/combine shims for Meteor require()..."' \
    '  mkdir -p "$H/factory" "$H/combine"' \
    '  echo "module.exports = require('"'"'../dist/cjs/helper/factory/index.js'"'"');" > "$H/factory/index.js"' \
    '  echo "module.exports = require('"'"'../dist/cjs/middleware/combine/index.js'"'"');" > "$H/combine/index.js"' \
    'fi' \
    'cd /app/bundle' \
    'exec node main.js' \
    > /docker-entrypoint.sh \
    && chmod 755 /docker-entrypoint.sh \
    && chown rocketchat:rocketchat /docker-entrypoint.sh

USER rocketchat

VOLUME /app/uploads

WORKDIR /app/bundle

EXPOSE 3000

ENTRYPOINT ["/docker-entrypoint.sh"]
